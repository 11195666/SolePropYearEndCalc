/* pages/index/index.wxss */
page { background-color: #f7f8fa; padding-bottom: 180rpx; }
.page-container { padding: 30rpx; }

.main-title { font-size: 36rpx; font-weight: 800; color: #333; margin-bottom: 30rpx; }
.subtitle-badge { font-size: 22rpx; color: #666; font-weight: normal; margin-top: 6rpx; }

/* 卡片通用 */
.card { background: #fff; border-radius: 24rpx; padding: 30rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03); }
.card-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 24rpx; }
.card-header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.static-info { font-size: 24rpx; color: #999; }
.divider { height: 1rpx; background: #f0f0f0; margin: 24rpx 0; }

/* --- 1. 优化后的输入行 --- */
.form-item { display: flex; justify-content: space-between; align-items: center; padding: 10rpx 0; }
.label-group { display: flex; flex-direction: column; }
.label { font-size: 28rpx; color: #333; }
.sub-label { font-size: 22rpx; color: #999; margin-top: 6rpx; }

/* 右侧输入容器 */
.input-row-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}
.input-lg { 
  text-align: right; 
  font-size: 36rpx; 
  font-weight: bold; 
  color: #333; 
  height: 60rpx; 
  width: 260rpx; /* 稍微留宽一点 */
}
.unit-group {
  display: flex;
  align-items: center;
  margin-left: 10rpx;
}
.unit { font-size: 28rpx; color: #333; }

/* 核心修改：简单的万字提示 */
.wan-tag {
  font-size: 22rpx;
  color: #0052d9; /* 蓝色高亮 */
  margin-left: 6rpx;
  white-space: nowrap;
}

/* 增值税 */
.vat-row-compact { display: flex; gap: 20rpx; margin-top: 10rpx; }
.vat-box { flex: 1; background: #f8f9fb; border: 1px solid #f0f0f0; border-radius: 12rpx; padding: 20rpx 10rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.vat-box.active { background: #f0f5ff; border-color: #0052d9; }
.vb-title { font-size: 26rpx; font-weight: bold; color: #333; margin-bottom: 4rpx; }
.vat-box.active .vb-title { color: #0052d9; }
.vb-desc { font-size: 20rpx; color: #999; }
.vat-box.active .vb-desc { color: #668ecf; }

/* 扣除项 */
.toggle-btn { background: #f0f5ff; color: #0052d9; text-align: center; padding: 20rpx; border-radius: 12rpx; font-size: 28rpx; display: flex; justify-content: center; align-items: center; gap: 10rpx; }
.toggle-btn.active { background: #f2f2f2; color: #666; }
.detail-container { margin-top: 20rpx; animation: slideDown 0.3s ease-out; }
.group-box { background: #fcfcfc; border: 1rpx solid #f0f0f0; border-radius: 16rpx; padding: 20rpx; margin-bottom: 20rpx; }
.group-title { font-size: 26rpx; font-weight: bold; color: #333; margin-bottom: 10rpx; display: flex; align-items: center; }
.tag-orange { font-size: 20rpx; color: #ff9c00; border: 1px solid #ff9c00; padding: 2rpx 8rpx; border-radius: 6rpx; margin-left: 10rpx; font-weight: normal; }

/* 提示框回归 */
.tips-box { background: #f4f4f4; color: #666; font-size: 22rpx; padding: 12rpx 16rpx; border-radius: 8rpx; margin-bottom: 16rpx; line-height: 1.4; }

.input-row { display: flex; justify-content: space-between; align-items: center; padding: 12rpx 0; min-height: 60rpx; }
.label-col { display: flex; flex-direction: column; justify-content: center; }
.i-label { font-size: 26rpx; color: #555; }
.i-right { display: flex; align-items: center; gap: 10rpx; }
.i-input { text-align: right; width: 140rpx; font-size: 30rpx; font-weight: bold; color: #333; }
.suffix { font-size: 24rpx; color: #999; }
.line { height: 1rpx; background: #eee; margin: 10rpx 0; }
.picker-row { background: #fff; border: 1rpx solid #eee; padding: 16rpx; border-radius: 8rpx; display: flex; justify-content: space-between; align-items: center; }
.picker-val { font-size: 26rpx; color: #0052d9; font-weight: bold; }

/* === 结果卡片 (上下结构版) === */
.result-area { margin-top: 40rpx; animation: slideUp 0.4s; }

.res-card-simple { 
  background: #fff; 
  border-radius: 24rpx 24rpx 0 0; 
  border-bottom: 1rpx solid #f5f5f5; 
  overflow: hidden; /* 防止圆角溢出 */
}

/* 上下布局容器 */
.stack-item {
  padding: 30rpx 40rpx;
  display: flex;
  flex-direction: column;
}

/* 上半部：利润区 */
.hero-section {
  background: #fff;
  align-items: center; /* 居中显示 */
  padding-bottom: 20rpx;
}

/* 下半部：税费区 */
.sub-section {
  background: #fcfcfc; /* 稍微带点灰，区分层次 */
  padding-top: 24rpx;
  padding-bottom: 30rpx;
}

/* 标签文字 */
.sr-lbl { 
  font-size: 26rpx; 
  color: #666; 
  margin-bottom: 12rpx;
}

/* 数字容器 */
.sr-val-box {
  display: flex;
  align-items: baseline;
  justify-content: center;
  flex-wrap: wrap; 
  word-break: break-all;
  line-height: 1;
  margin-bottom: 12rpx;
  width: 100%;
}

/* 左对齐模式 (用于下半部) */
.sr-val-box.align-left {
  justify-content: flex-start;
}

.sr-val-box .unit { 
  font-size: 36rpx; 
  margin-right: 8rpx; 
  font-weight: bold; 
  color: #333; 
}

.sr-val-box .unit.small {
  font-size: 32rpx;
}

.sr-val-box .num { font-weight: 800; font-family: 'DIN', sans-serif; } /* 推荐用数字字体，如果没有则回退 */

/* 核心大数字 */
.hero-num { font-size: 72rpx; } /* 超大字号 */
.num.green { color: #07c160; }

/* 次级数字 */
.num.red { color: #e34d59; font-size: 48rpx; }

/* 标签行 */
.tag-row { display: flex; justify-content: center; width: 100%; }
.sr-tag { 
  font-size: 22rpx; 
  background: #e6f9ed; 
  color: #07c160; 
  padding: 4rpx 16rpx; 
  border-radius: 20rpx; 
}

/* 下半部标题行 (左右分布) */
.sub-row-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  margin-bottom: 10rpx;
}

.sr-sub { 
  font-size: 22rpx; 
  color: #999; 
  background: #f0f0f0;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

/* 水平分割线 */
.h-line {
  height: 1rpx;
  background: #eee;
  width: 90%;
  margin: 0 auto; /* 居中 */
}

/* 列表详情 */
.list-card { background: #fff; border-radius: 0 0 24rpx 24rpx; padding: 0; overflow: hidden; margin-bottom: 24rpx; }
.list-title { background: #fcfcfc; padding: 20rpx 30rpx; font-size: 26rpx; font-weight: bold; color: #666; border-bottom: 1rpx solid #f5f5f5; }
.list-row { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 30rpx; }
.hover-row:active { background-color: #f5f7fa; }
.name-box { display: flex; align-items: center; }
.help-icon { width: 28rpx; height: 28rpx; line-height: 28rpx; text-align: center; border: 1px solid #0052d9; color: #0052d9; font-size: 20rpx; border-radius: 50%; margin-left: 10rpx; display: inline-block; font-weight: bold; }
.lr-name { font-size: 28rpx; color: #333; }
.lr-desc { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.lr-val { font-size: 30rpx; font-weight: bold; color: #333; }
.lr-val.big { color: #0052d9; }
.divider-dashed { border-top: 1px dashed #eee; margin: 0 30rpx; }
.tags-group { margin-top: 6rpx; display: flex; gap: 10rpx; }
.tag-gray { font-size: 20rpx; background: #f2f2f2; color: #666; padding: 2rpx 8rpx; border-radius: 4rpx; }

.footer-tips-light { text-align: center; font-size: 22rpx; color: #bbb; }
.footer-bar { position: fixed; bottom: 0; left: 0; width: 100%; background: #fff; padding: 20rpx 30rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05); display: flex; gap: 20rpx; box-sizing: border-box; z-index: 100; }
.btn { margin: 0; border-radius: 40rpx; font-size: 30rpx; height: 80rpx; line-height: 80rpx; }
.btn.reset { width: 250rpx; background: #f0f0f0; color: #666; }
.btn.calc { flex: 1; background: #0052d9; color: #fff; }

@keyframes slideDown { from { opacity: 0; transform: translateY(-10rpx); } to { opacity: 1; transform: translateY(0); } }
@keyframes slideUp { from { opacity: 0; transform: translateY(20rpx); } to { opacity: 1; transform: translateY(0); } }
